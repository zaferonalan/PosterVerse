{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@my-app/source"],
    "paths": {
      "@my-app/ui": ["packages/ui/src/index.ts"],
      "@my-app/ui/*": ["packages/ui/src/*"],
      "@my-app/database": ["packages/database/src/index.ts"],
      "@my-app/database/*": ["packages/database/src/*"],
      "@my-app/schemas": ["packages/schemas/src/index.ts"],
      "@my-app/schemas/*": ["packages/schemas/src/*"]
    }
  },
  
}
